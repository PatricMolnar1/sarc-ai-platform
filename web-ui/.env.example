# Copy to `.env` to override defaults.

# Use the in-memory mock API instead of the real Core Backend.
# Defaults to "true" until the Spring Boot backend exists.
VITE_USE_MOCK=true

# Base URL for the Core Backend (port 8080).
# Leave as "/core" to use the Vite dev proxy (see vite.config.ts).
VITE_CORE_API_BASE=/core
